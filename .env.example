# =============================================================================
# ENAJU-GCPJ — Variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o .env no repositório.
# =============================================================================

# --- Scopus (Elsevier) ---
# Obtenha em: https://dev.elsevier.com/
SCOPUS_API_KEY=your_scopus_api_key_here
SCOPUS_INST_TOKEN=your_institution_token_here_if_applicable

# --- Semantic Scholar ---
# Obtenha em: https://api.semanticscholar.org/
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here

# --- Crossref (polite pool) ---
# Não requer chave; use email institucional para acesso ao polite pool
CROSSREF_EMAIL=your.email@institution.br

# --- OpenAlex (polite pool) ---
# Não requer chave; email melhora throughput
OPENALEX_EMAIL=your.email@institution.br

# --- SciELO ---
# Acesso aberto; nenhuma chave necessária
# Variável mantida para compatibilidade futura
SCIELO_EMAIL=your.email@institution.br

# --- Configuração geral do projeto ---
# Caminho absoluto para a raiz do projeto (opcional, detectado automaticamente)
# PROJECT_ROOT=/home/user/enaju-gcpj
